# ── Instabet Agent — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── 0G Compute (required) ─────────────────────────────────────────────────────

# Your EVM wallet private key (funded with 0G tokens for inference payments)
# Get testnet tokens: https://faucet.0g.ai
ZG_WALLET_PRIVATE_KEY=0x...your_private_key_here...

# 0G provider address to use for inference
# Testnet Qwen 2.5 7B provider:
ZG_PROVIDER_ADDRESS=0xa48f01...

# Which 0G network to use: testnet or mainnet
ZG_NETWORK=testnet

# How much 0G to deposit into your ledger account (initial setup, one-time)
ZG_DEPOSIT_AMOUNT=5

# How much 0G to transfer to the provider sub-account (minimum 1)
ZG_PROVIDER_FUND=2

# API key for the 0G broker proxy (the sidecar uses this internally)
# This can be any string — it's just for intra-container auth
ZG_API_KEY=zg-broker-local

# ── Instabet API (required) ───────────────────────────────────────────────────

# Base URL of the Instabet backend API
INSTABET_BASE_URL=https://api.instabet.xyz/v1

# Your Instabet API key (get this from the Instabet backend)
INSTABET_API_KEY=your_instabet_api_key_here

# ── Trading parameters (optional, have defaults) ─────────────────────────────

# Amount to bet per market (in the market's native currency)
BET_AMOUNT=0.01

# Minimum confidence (0-1) required to place a bet
# 0.65 = agent must be 65%+ confident to bet
CONFIDENCE_THRESHOLD=0.65

# Cron schedule for the trading loop (standard 5-field cron expression)
# Default: every 5 minutes
# Examples:
#   */2 * * * *   = every 2 minutes
#   */10 * * * *  = every 10 minutes
#   0 * * * *     = every hour
CRON_INTERVAL=*/5 * * * *

# ── OpenClaw gateway (optional) ──────────────────────────────────────────────

# Password for the OpenClaw gateway web UI (http://localhost:18789)
# Change this to something secure if you expose the port externally
OPENCLAW_PASSWORD=change-me-to-something-secure
